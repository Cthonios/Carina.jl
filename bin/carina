#!/usr/bin/env julia
# CLI entry point for Carina.jl
#
# Usage (from anywhere):
#   /path/to/Carina.jl/bin/carina input.yaml
#   /path/to/Carina.jl/bin/carina input.yaml --device rocm
#   /path/to/Carina.jl/bin/carina input.yaml --device cuda
#   /path/to/Carina.jl/bin/carina input.yaml --device cpu
#
# --device overrides the "device:" key in the YAML file.

import Pkg
Pkg.activate(joinpath(@__DIR__, ".."); io=devnull)

using Carina

function _parse_args(args)
    yaml_file = nothing
    device    = nothing
    i = 1
    while i <= length(args)
        if args[i] == "--device" && i < length(args)
            device = args[i + 1]
            i += 2
        elseif yaml_file === nothing && !startswith(args[i], "-")
            yaml_file = args[i]
            i += 1
        else
            println(stderr, "Usage: carina <input.yaml> [--device cpu|rocm|cuda]")
            exit(1)
        end
    end
    if yaml_file === nothing
        println(stderr, "Usage: carina <input.yaml> [--device cpu|rocm|cuda]")
        exit(1)
    end
    return yaml_file, device
end

yaml_file, device = _parse_args(ARGS)
Carina.run(yaml_file; device=device)
