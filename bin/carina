#!/bin/bash
# CLI entry point for Carina.jl
#
# Usage:
#   bin/carina input.yaml
#   bin/carina input.yaml --device rocm
#   bin/carina input.yaml --threads 8
#   bin/carina input.yaml --threads 8 --device cuda

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Parse --threads flag (must be extracted before passing to Julia)
THREADS=""
JULIA_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --threads|-t)
            THREADS="$2"
            shift 2
            ;;
        *)
            JULIA_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -z "${JULIA_ARGS[*]}" ]]; then
    echo "Usage: carina <input.yaml> [--device cpu|rocm|cuda] [--threads N]" >&2
    exit 1
fi

THREAD_FLAG=""
if [[ -n "$THREADS" ]]; then
    THREAD_FLAG="-t $THREADS"
fi

exec julia $THREAD_FLAG --project="$PROJECT_DIR" "$PROJECT_DIR/src/Carina.jl" "${JULIA_ARGS[@]}"
