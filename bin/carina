#!/bin/bash
# CLI entry point for Carina.jl
#
# Usage:
#   carina input.yaml
#   carina input.yaml --device cuda
#   carina input.yaml --device auto --threads 8
#
# Runs the launcher environment in bin/ (bin/Project.toml), which owns the GPU
# vendor packages so the Carina library itself stays vendor-free.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"   # the launcher environment (bin/)

# Extract --threads / -t before handing the rest to Julia.
THREADS=""
JULIA_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --threads|-t)
            THREADS="$2"
            shift 2
            ;;
        *)
            JULIA_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -z "${JULIA_ARGS[*]}" ]]; then
    echo "Usage: carina <input.yaml> [--device cpu|cuda|rocm|auto] [--threads N]" >&2
    exit 1
fi

THREAD_FLAG=""
[[ -n "$THREADS" ]] && THREAD_FLAG="-t $THREADS"

# Instantiate the launcher environment on first use (one-time).
if [[ ! -f "$SCRIPT_DIR/Manifest.toml" ]]; then
    echo "carina: first run — instantiating launcher environment (one-time)..." >&2
    julia --project="$SCRIPT_DIR" -e 'import Pkg; Pkg.instantiate()' || {
        echo "carina: failed to instantiate the launcher environment" >&2
        exit 1
    }
fi

exec julia $THREAD_FLAG --project="$SCRIPT_DIR" "$SCRIPT_DIR/carina.jl" "${JULIA_ARGS[@]}"
